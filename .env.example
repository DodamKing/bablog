# 이 파일을 .env.local 로 복사한 뒤 값을 채운다. (.env.local 은 git에 올리지 않음)

# Neon Postgres 연결 문자열 (Neon 대시보드 > Connection string > "Pooled" 권장)
# 예: postgresql://USER:PASSWORD@ep-xxxx-pooler.region.aws.neon.tech/DB?sslmode=require
# 개발 편의: dev 서버에서 카카오 로그인 없이 고정 dev 사용자로 진행 (배포에선 무시됨).
# 모바일 LAN 테스트 시 유용. 비워두면 정상 로그인 사용.
DEV_AUTH_BYPASS=

DATABASE_URL=

# Auth.js 세션 서명 키. 생성: openssl rand -base64 32
AUTH_SECRET=

# 카카오 로그인 (카카오 개발자 콘솔 > 내 애플리케이션에서 발급)
# AUTH_KAKAO_ID     = REST API 키
# AUTH_KAKAO_SECRET = 보안 > Client Secret (활성화 후 발급)
AUTH_KAKAO_ID=
AUTH_KAKAO_SECRET=

# Gemini (사진 영양 분석) — Google AI Studio 발급 키
GEMINI_API_KEY=

# Cloudflare R2 (사진 보관 — D17). S3 호환.
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
# 공개 이미지 베이스 URL (r2.dev 공개 URL 또는 커스텀 도메인), 끝에 / 없이
R2_PUBLIC_URL=
