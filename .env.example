# 이 파일을 .env.local 로 복사한 뒤 값을 채운다. (.env.local 은 git에 올리지 않음)

# Neon Postgres 연결 문자열 (Neon 대시보드 > Connection string > "Pooled" 권장)
# 예: postgresql://USER:PASSWORD@ep-xxxx-pooler.region.aws.neon.tech/DB?sslmode=require
DATABASE_URL=

# Auth.js 세션 서명 키. 생성: openssl rand -base64 32
AUTH_SECRET=

# 카카오 로그인 (카카오 개발자 콘솔 > 내 애플리케이션에서 발급)
# AUTH_KAKAO_ID     = REST API 키
# AUTH_KAKAO_SECRET = 보안 > Client Secret (활성화 후 발급)
AUTH_KAKAO_ID=
AUTH_KAKAO_SECRET=
